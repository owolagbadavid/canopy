{
  "name": "canopy",
  "version": "1.0.0",
  "private": true,
  "description": "Canopy — orchard intelligence dashboard built on the WeatherAI API",
  "workspaces": [
    "server",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev -w server\" \"npm:dev -w web\"",
    "build": "npm run build -w web && npm run build -w server",
    "start": "node server/dist/index.js",
    "clean": "rm -rf server/dist web/dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
