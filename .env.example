WEATHER_AI_KEY=wai_your_key_here
WEATHER_AI_BASE_URL=https://api.weather-ai.co

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

MONGO_URL=mongodb://localhost:27017/canopy
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# Cache: "memory" (default) or "redis"
CACHE_DRIVER=memory
REDIS_URL=redis://localhost:6379
# Rate limiting (per window). Anonymous is keyed per-IP and capped lower;
# authenticated is keyed per-user with a higher cap.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=15
RATE_LIMIT_AUTH_MAX=30
